---
import BaseLayout from '../layouts/BaseLayout.astro';
import { renderMarkdown } from '../lib/markdown';
import { readContentFile } from '../lib/utils';

const content = readContentFile('about.md');
const html = renderMarkdown(content);
---

<BaseLayout>
  <div class="page">
    <div set:html={html} />
  </div>
</BaseLayout>

---
const links = [
  { href: 'https://x.com/newsystems_', label: 'Twitter' },
  { href: 'https://www.instagram.com/newsystems_/', label: 'Instagram' },
  { href: 'https://lu.ma/newsystems', label: 'Luma' },
  { href: 'mailto:email@newsystems.ca', label: 'Contact' },
];
---

<footer>
  <nav>
    {links.map(link => (
      <a
        href={link.href}
        target={link.href.startsWith('http') ? '_blank' : undefined}
        rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
      >
        {link.label}
      </a>
    ))}
  </nav>
</footer>

<style>
  footer {
    width: 100%;
    margin: 0;
    padding: 1rem 1.5rem 1.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--font-size-base);
  }

  nav {
    display: flex;
    gap: var(--spacing-lg);
    align-items: center;
  }

  nav a {
    color: var(--text-muted);
    text-decoration: none;
  }

  nav a:hover {
    color: var(--link-hover);
  }

  /* Mobile */
  @media (max-width: 600px) {
    footer {
      padding: 1rem 1rem 1rem;
    }

    nav {
      flex-wrap: wrap;
      gap: var(--spacing-sm);
    }
  }
</style>
